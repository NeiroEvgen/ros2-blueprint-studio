import rclpy
from rclpy.node import Node

def main():
    rclpy.init()
    node = Node('spy_node')
    print("=== СПИСОК ТОПИКОВ ROS 2 ===")
    for name, types in node.get_topic_names_and_types():
        print(f"Topic: {name} | Type: {types}")
    print("============================")
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__': main()